# Set default behavior to automatically normalize line endings.
*           text=auto eol=lf

# Override the defaults for individual file types
*.bash      diff=bash
*.bat       eol=crlf
*.cmd       eol=crlf
*.cs        diff=csharp
*.cshtml    diff=html
*.css       diff=css
*.md        diff=markdown
*.sh        diff=bash

# Fix syntax highlighting on GitHub to allow comments
.vscode/*.json linguist-language=JSON-with-Comments
